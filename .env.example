# --- Сервер ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- Reverse-proxy (Caddy, docker-compose) ---
# Локально не задавать → Caddy слушает :80 (HTTP, http://localhost).
# В проде: SITE_DOMAIN=tolkay-voda.ru → авто-HTTPS (Let's Encrypt).
SITE_DOMAIN=

# --- S3 (Beget) ---
S3_REGION=ru-central-1
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_BUCKET=cf49406a2f83-incomparable-darian
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Публичный базовый URL для отдачи файлов (CDN)
CDN_BASE_URL=https://ceshocofureled.begetcdn.cloud

# --- Telegram-бот ---
BOT_TOKEN=
# Разрешённые Telegram user id через запятую (кто может постить контент)
BOT_ADMIN_IDS=

# --- OpenAI (выжимка прогноза дня из сырого текста) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- База ---
DB_PATH=./data/app.db

# --- Эфир (Icecast + Liquidsoap, этап 11) ---
# Внутренние пароли Icecast (источник + админка). Наружу не торчат — Icecast
# доступен только через Caddy на /stream. Задайте свои случайные значения.
ICECAST_SOURCE_PASSWORD=
ICECAST_ADMIN_PASSWORD=
# Хост Icecast для app/liquidsoap внутри docker-сети (по умолчанию icecast).
ICECAST_HOST=icecast
